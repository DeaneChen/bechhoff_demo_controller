             xmlns:local="clr-namespace:PcHostGUI"
             xmlns:modernWpf="clr-namespace:ModernWpf;assembly=ModernWpf"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <modernWpf:ThemeResources />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
