<Window x:Class="PcHostGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PcHostGUI.ViewModels"
        xmlns:mwc="clr-namespace:ModernWpf.Controls;assembly=ModernWpf.Controls"
        xmlns:mw="clr-namespace:ModernWpf.Controls;assembly=ModernWpf"
        mc:Ignorable="d"
        Title="PcHostGUI"
        Height="780"
        Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

        <mwc:NavigationView x:Name="Nav"
                        AlwaysShowHeader="True"
                        PaneTitle="VariableBlade"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        SelectionChanged="Nav_OnSelectionChanged">
        <mwc:NavigationView.MenuItems>
            <mwc:NavigationViewItem Content="Control Panel" Tag="control">
                <mwc:NavigationViewItem.Icon>
                    <mw:SymbolIcon Symbol="Bullets" />
                </mwc:NavigationViewItem.Icon>
            </mwc:NavigationViewItem>
            <mwc:NavigationViewItemSeparator />
            <mwc:NavigationViewItem Content="Logs" Tag="logs">
                <mwc:NavigationViewItem.Icon>
                    <mw:SymbolIcon Symbol="List" />
                </mwc:NavigationViewItem.Icon>
            </mwc:NavigationViewItem>
        </mwc:NavigationView.MenuItems>

        <mwc:NavigationView.Header>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AMS NetId" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Width="210" Text="{Binding AmsNetId, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
                    <TextBlock Text="Port" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <TextBox Width="80" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />

                    <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="12,0,0,0" MinWidth="88" />
                    <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Margin="8,0,0,0" MinWidth="88" />
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding StatusText}" />
                    <TextBlock Text="{Binding LatestLogMessage}" MaxWidth="520" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </mwc:NavigationView.Header>

        <Grid>
            <ContentControl x:Name="PageHost" />
        </Grid>
    </mwc:NavigationView>
</Window>
