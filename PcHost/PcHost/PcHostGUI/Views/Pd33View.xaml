<UserControl x:Class="PcHostGUI.Views.Pd33View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Laser (PD33)" FontSize="22" FontWeight="SemiBold" />

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Border CornerRadius="8" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Config" FontSize="16" FontWeight="SemiBold" />

                        <WrapPanel Margin="0,12,0,0">
                            <CheckBox Content="Enable" IsChecked="{Binding Enable}" Margin="0,0,18,10" />
                            <TextBlock Text="Channel" VerticalAlignment="Center" Margin="0,0,8,10" />
                            <TextBox Width="60" Text="{Binding ChannelInt, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Margin="0,0,18,10" />
                            <TextBlock Text="SlaveId" VerticalAlignment="Center" Margin="0,0,8,10" />
                            <TextBox Width="60" Text="{Binding SlaveIdInt, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Margin="0,0,18,10" />
                            <CheckBox Content="Low word first (WordSwap32)" IsChecked="{Binding WordSwap32}" Margin="0,0,18,10" />
                            <CheckBox Content="Reserved: active read 0x003B disabled in passive mode" IsChecked="{Binding UseDisplayRegister3B}" Margin="0,0,18,10" />
                        </WrapPanel>

                        <WrapPanel>
                            <Button Content="Apply" Command="{Binding ApplyCommand}" Margin="0,0,10,10" />
                            <Button Content="Zero" Command="{Binding ZeroCommand}" Margin="0,0,10,10" />
                            <Button Content="Cancel zero" Command="{Binding CancelZeroCommand}" Margin="0,0,10,10" />
                        </WrapPanel>

                        <TextBlock Text="Tip: If ChannelConflict=true, choose another EL6022 channel or disable NimServo."
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" CornerRadius="8" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Telemetry" FontSize="16" FontWeight="SemiBold" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ChannelConflict" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ChannelConflict}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Busy" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Busy}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CommOk" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CommOk}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="PortReady" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PortReady}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="CommErrorCount" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CommErrorCount}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="LastErrorId" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LastErrorId}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="RxDiscardCount" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RxDiscardCount}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="LastDiscardId" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding LastDiscardId}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="ExceptionCode" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ExceptionCode}" />

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Abs (mm)" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding AbsMm, StringFormat={}{0:F4}}" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Rel (mm)" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding RelMm, StringFormat={}{0:F3}}" />

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="AbsRaw / RelRaw" Margin="0,0,12,6" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding AbsRaw}" />
                            <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding RelRaw}" />
                        </Grid>

                        <TextBlock Text="{Binding LastTelemetryUtc, StringFormat=Last update (UTC): {0:HH:mm:ss.fff}}"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
