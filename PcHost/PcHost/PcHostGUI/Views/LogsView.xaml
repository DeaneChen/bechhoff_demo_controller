<UserControl x:Class="PcHostGUI.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock Text="Logs" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
            <Button Content="Clear" Command="{Binding ClearLogsCommand}" DockPanel.Dock="Right" />
        </DockPanel>

        <Border Grid.Row="2" CornerRadius="8" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" Padding="6">
            <ListView ItemsSource="{Binding Logs}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True" Margin="6,2">
                            <TextBlock DockPanel.Dock="Left" Width="120" Text="{Binding Utc, StringFormat={}{0:HH:mm:ss.fff}}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock DockPanel.Dock="Left" Width="60" Text="{Binding Level}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</UserControl>

