<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.13">
  <POU Name="FB_PD33" Id="{b5a62a1d-4ccf-4aa3-9a63-6a8d5fd85b4f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_PD33
VAR_INPUT
    Enable : BOOL;
    Channel : USINT; // 1 or 2
    SlaveId : USINT; // 1..247
    WordSwap32 : BOOL; // TRUE: low word first (matches PD33 manual examples)
    UseDisplayRegister3B : BOOL; // reserved: PD33 now uses passive full-speed output parsing

    CmdSeq : UDINT;
    Cmd : USINT; // reserved in passive mode
END_VAR
VAR_OUTPUT
    CmdAckSeq : UDINT;
    Busy : BOOL;

    PortReady : BOOL;
    CommOk : BOOL;
    CommErrorCount : UDINT;
    LastErrorId : UDINT;
    ExceptionCode : USINT;
    RxDiscardCount : UDINT;
    LastDiscardId : UDINT;

    AbsRaw : DINT;
    RelRaw : DINT;
    AbsMm : LREAL;
    RelMm : LREAL;
    ZeroWord : UINT;

    LastTxLen : USINT;
    LastTx : ARRAY [0..21] OF USINT;
    LastRxLen : USINT;
    LastRx : ARRAY [0..21] OF USINT;
END_VAR
VAR
    fbPort : FB_EL6022_Port;
    txData : ARRAY [0..21] OF USINT;
    rx : ARRAY [0..21] OF USINT;
    rxLen : USINT;
    crcRx : WORD;
    crcCalc : WORD;
    low : UINT;
    high : UINT;
    uTmp : UDINT;
    dw : DWORD;
    i : USINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT Enable THEN
    fbPort(Enable := FALSE, Channel := Channel, TxStart := FALSE, TxLen := 0, TxData := txData);

    Busy := FALSE;
    PortReady := FALSE;
    CommOk := FALSE;
    AbsRaw := 0;
    RelRaw := 0;
    AbsMm := 0.0;
    RelMm := 0.0;
    ZeroWord := 0;
    LastTxLen := 0;
    LastRxLen := 0;
    LastErrorId := 0;
    ExceptionCode := 0;
    RxDiscardCount := 0;
    LastDiscardId := 0;
    RETURN;
END_IF

// Passive mode: PD33 is configured for full-speed active output.
// The PLC only initializes/acknowledges the EL6022 channel and parses received frames.
fbPort(Enable := TRUE, Channel := Channel, TxStart := FALSE, TxLen := 0, TxData := txData);

Busy := FALSE;
PortReady := fbPort.Ready;
ExceptionCode := 0;
LastTxLen := 0;

IF CmdSeq <> CmdAckSeq THEN
    // Active zero/cancel writes are intentionally disabled while the sensor is in full-speed output mode.
    CmdAckSeq := CmdSeq;
END_IF

IF fbPort.RxNew THEN
    rxLen := fbPort.RxLen;
    rx := fbPort.RxData;
    LastRxLen := rxLen;
    LastRx := rx;

    IF rxLen <> 9 THEN
        RxDiscardCount := RxDiscardCount + 1;
        LastDiscardId := 16#00030001; // passive discard: unexpected frame length
        CommOk := FALSE;
        CommErrorCount := CommErrorCount + 1;
        LastErrorId := LastDiscardId;
        RETURN;
    END_IF

    IF rx[0] <> SlaveId THEN
        RxDiscardCount := RxDiscardCount + 1;
        LastDiscardId := 16#00030002; // passive discard: wrong slave id
        CommOk := FALSE;
        CommErrorCount := CommErrorCount + 1;
        LastErrorId := LastDiscardId;
        RETURN;
    END_IF

    IF (rx[1] <> 3) OR (rx[2] <> 4) THEN
        RxDiscardCount := RxDiscardCount + 1;
        LastDiscardId := 16#00030003; // passive discard: unexpected function/byte count
        CommOk := FALSE;
        CommErrorCount := CommErrorCount + 1;
        LastErrorId := LastDiscardId;
        RETURN;
    END_IF

    crcRx := USINT_TO_WORD(rx[7]) OR SHL(USINT_TO_WORD(rx[8]), 8);
    crcCalc := F_ModbusCrc16(rx, 7);
    IF crcRx <> crcCalc THEN
        RxDiscardCount := RxDiscardCount + 1;
        LastDiscardId := 16#00030004; // passive discard: crc mismatch
        CommOk := FALSE;
        CommErrorCount := CommErrorCount + 1;
        LastErrorId := LastDiscardId;
        RETURN;
    END_IF

    high := SHL(USINT_TO_UINT(rx[3]), 8) OR USINT_TO_UINT(rx[4]);
    low := SHL(USINT_TO_UINT(rx[5]), 8) OR USINT_TO_UINT(rx[6]);
    IF WordSwap32 THEN
        high := SHL(USINT_TO_UINT(rx[5]), 8) OR USINT_TO_UINT(rx[6]);
        low := SHL(USINT_TO_UINT(rx[3]), 8) OR USINT_TO_UINT(rx[4]);
    END_IF

    uTmp := SHL(UINT_TO_UDINT(high), 16) OR UINT_TO_UDINT(low);
    dw := UDINT_TO_DWORD(uTmp);
    RelRaw := DWORD_TO_DINT(dw);
    RelMm := DINT_TO_LREAL(RelRaw) / 1000.0;
    AbsRaw := RelRaw;
    AbsMm := RelMm;

    CommOk := TRUE;
    LastErrorId := 0;
    LastDiscardId := 0;
END_IF
]]></ST>
    </Implementation>
    <LineIds Name="FB_PD33">
      <LineId Id="1" Count="140" />
    </LineIds>
  </POU>
</TcPlcObject>
